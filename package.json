{
  "name": "fresco",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc --noEmit && vite build",
    "preview": "vite preview",
    "dev:full": "powershell -ExecutionPolicy Bypass -File dev.ps1",
    "tauri": "tauri",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "oxlint src/",
    "lint:rust": "cargo clippy --manifest-path src-tauri/Cargo.toml -- -D warnings",
    "lint:all": "pnpm lint && pnpm lint:rust",
    "format": "prettier --write src/"
  },
  "dependencies": {
    "@tauri-apps/api": "^2",
    "@tauri-apps/plugin-notification": "^2.3.3",
    "@tauri-apps/plugin-opener": "^2",
    "@tauri-apps/plugin-process": "^2.3.1",
    "pinia": "^3.0.4",
    "vue": "^3.5.13",
    "vue-router": "^5.0.2"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2",
    "@vitejs/plugin-vue": "^5.2.1",
    "@vue/test-utils": "^2.4.6",
    "happy-dom": "^20.6.1",
    "oxlint": "^1.47.0",
    "prettier": "^3.8.1",
    "typescript": "~5.6.2",
    "vite": "^6.0.3",
    "vitest": "^4.0.18",
    "vue-tsc": "^2.1.10"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  }
}
